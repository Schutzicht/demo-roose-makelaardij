---
import { siteConfig } from '../../data/siteConfig';
import { type Lang, t } from '../../data/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'nl' } = Astro.props;
const prefix = lang === 'nl' ? '' : `/${lang}`;
---

<footer class="bg-secondary-800 text-white pb-20 lg:pb-0">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/logo.svg" alt="Roose Makelaardij logo" class="w-10 h-10 object-contain" />
          <span class="text-lg font-bold">{siteConfig.shortName}</span>
        </div>
        <p class="text-secondary-300 text-sm leading-relaxed mb-6">
          {siteConfig.tagline}. Lid NVM en Funda partner.
        </p>
        <div class="flex gap-3">
          <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-secondary-700 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-secondary-700 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z"/></svg>
          </a>
        </div>
      </div>

      <!-- Navigatie -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-secondary-300 mb-4">{t('footer.navigation', lang)}</h3>
        <ul class="space-y-2.5">
          <li><a href={`${prefix}/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.home', lang)}</a></li>
          <li><a href={`${prefix}/aanbod/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.properties', lang)}</a></li>
          <li><a href={`${prefix}/verkocht/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.sold', lang)}</a></li>
          <li><a href={`${prefix}/diensten/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.services', lang)}</a></li>
          <li><a href={`${prefix}/over-ons/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.about', lang)}</a></li>
          <li><a href={`${prefix}/contact/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.contact', lang)}</a></li>
        </ul>
      </div>

      <!-- Diensten -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-secondary-300 mb-4">{t('footer.services', lang)}</h3>
        <ul class="space-y-2.5">
          <li><a href={`${prefix}/diensten/verkopen/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('footer.sellService', lang)}</a></li>
          <li><a href={`${prefix}/diensten/waardebepaling/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('footer.valuationService', lang)}</a></li>
          <li><a href={`${prefix}/diensten/inschrijven/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('footer.searchService', lang)}</a></li>
          <li><a href={`${prefix}/vakantieverhuur/`} class="text-secondary-400 hover:text-white transition-colors text-sm">{t('nav.holidayRental', lang)}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-secondary-300 mb-4">{t('footer.contact', lang)}</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-secondary-300">
              {siteConfig.contact.address}<br />
              {siteConfig.contact.postalCode} {siteConfig.contact.city}
            </span>
          </li>
          <li>
            <a href={`tel:${siteConfig.contact.phone}`} class="flex items-center gap-3 text-sm text-secondary-300 hover:text-white transition-colors">
              <svg class="w-5 h-5 text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {siteConfig.contact.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.contact.email}`} class="flex items-center gap-3 text-sm text-secondary-300 hover:text-white transition-colors">
              <svg class="w-5 h-5 text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {siteConfig.contact.email}
            </a>
          </li>
        </ul>

        <!-- Openingstijden compact -->
        <div class="mt-6">
          <h4 class="text-xs font-bold uppercase tracking-wider text-secondary-400 mb-2">{t('footer.hours', lang)}</h4>
          <p class="text-sm text-secondary-300">Ma - Vr: 09:00 - 17:00</p>
          <p class="text-sm text-secondary-300">Za: op afspraak</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-secondary-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-xs text-secondary-500">
          &copy; {new Date().getFullYear()} {siteConfig.name}. {t('footer.rights', lang)}
        </p>
        <div class="flex items-center gap-4 text-xs text-secondary-500">
          <span>KvK: {siteConfig.business.kvk}</span>
          <span class="hidden sm:inline">|</span>
          <span>BTW: {siteConfig.business.btw}</span>
        </div>
      </div>
    </div>
  </div>
</footer>
