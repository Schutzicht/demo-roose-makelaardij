---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/siteConfig';
import { type Lang, t } from '../../data/translations';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title,
  description,
  lang = 'nl',
} = Astro.props;

const ctaTitle = title || t('cta.title', lang);
const ctaDesc = description || t('cta.description', lang);
const prefix = lang === 'nl' ? '' : `/${lang}`;
---

<section class="relative py-24 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/fotos roose maakelaardij/foto van gebouw vanaf buiten 2.jpeg" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/90 via-primary-800/85 to-primary-700/80"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
      <div class="lg:col-span-3 reveal">
        <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-sm text-white/90 font-medium mb-6">
          <span class="w-2 h-2 bg-accent-400 rounded-full"></span>
          Gratis & vrijblijvend
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">{ctaTitle}</h2>
        <p class="text-primary-200 text-lg mb-8 max-w-xl">{ctaDesc}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={`${prefix}/diensten/waardebepaling/`} variant="white" size="lg">
            {t('cta.valuation', lang)}
          </Button>
          <Button href={`tel:${siteConfig.contact.phone}`} variant="outline" size="lg" class="border-white/30 text-white hover:bg-white hover:text-primary-700">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Bel {siteConfig.contact.phone}
          </Button>
        </div>
      </div>
      <div class="lg:col-span-2 reveal hidden lg:block" style="transition-delay: 0.2s;">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 p-8">
          <h3 class="text-white font-bold text-lg mb-4">{t('cta.quickContact', lang)}</h3>
          <div class="space-y-4">
            <a href={`tel:${siteConfig.contact.phone}`} class="flex items-center gap-3 text-white/80 hover:text-white transition-colors">
              <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <span class="font-medium">{siteConfig.contact.phone}</span>
            </a>
            <a href={`mailto:${siteConfig.contact.email}`} class="flex items-center gap-3 text-white/80 hover:text-white transition-colors">
              <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <span class="font-medium">{siteConfig.contact.email}</span>
            </a>
            <div class="flex items-center gap-3 text-white/80">
              <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <span class="font-medium">{siteConfig.contact.address}, {siteConfig.contact.city}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
