---
interface Props {
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { subtitle, align = 'center', light = false } = Astro.props;
---

<div class:list={['mb-12', align === 'center' && 'text-center']}>
  {subtitle && (
    <span class:list={[
      'text-sm font-bold uppercase tracking-widest mb-3 block',
      light ? 'text-primary-300' : 'text-primary-500',
    ]}>
      {subtitle}
    </span>
  )}
  <h2 class:list={[
    'text-3xl sm:text-4xl font-bold leading-tight',
    light ? 'text-white' : 'text-secondary-800',
  ]}>
    <slot />
  </h2>
  <div class:list={[
    'w-16 h-1 rounded-full mt-4',
    light ? 'bg-primary-400' : 'bg-primary-500',
    align === 'center' && 'mx-auto',
  ]}></div>
</div>
