---
import Badge from '../ui/Badge.astro';
import { formatPrice } from '../../utils/helpers';

interface Props {
  slug: string;
  title: string;
  location: string;
  postalCode: string;
  price: number;
  image: string;
  bedrooms: number;
  area: number;
  type: string;
  status: 'nieuw' | 'te koop' | 'verkocht' | 'onder bod' | 'verhuurd';
}

const { slug, title, location, postalCode, price, image, bedrooms, area, type, status } = Astro.props;

const statusMap = {
  'nieuw': { label: 'Nieuw', variant: 'new' as const },
  'te koop': { label: 'Te koop', variant: 'default' as const },
  'verkocht': { label: 'Verkocht', variant: 'sold' as const },
  'onder bod': { label: 'Onder bod', variant: 'reserved' as const },
  'verhuurd': { label: 'Verhuurd', variant: 'rent' as const },
};

const statusInfo = statusMap[status];
---

<a href={`/aanbod/${slug}/`} class="group block bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-1.5">
  <!-- Image -->
  <div class="relative aspect-[16/10] overflow-hidden">
    <img
      src={image}
      alt={`${title} - ${location}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      loading="lazy"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>

    <!-- Status badge -->
    <div class="absolute top-3 left-3">
      <Badge variant={statusInfo.variant}>{statusInfo.label}</Badge>
    </div>

    <!-- Price on image -->
    <div class="absolute bottom-3 left-3">
      <span class="text-xl font-bold text-white drop-shadow-lg">
        {status === 'verkocht' ? 'Verkocht' : `${formatPrice(price)}`}
      </span>
      {status !== 'verkocht' && <span class="text-white/70 text-xs ml-1">k.k.</span>}
    </div>

    <!-- Type label -->
    <div class="absolute top-3 right-3">
      <span class="bg-white/20 backdrop-blur-sm text-white text-xs font-medium px-2.5 py-1 rounded-md border border-white/20 capitalize">
        {type}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-5">
    <!-- Address -->
    <h3 class="text-base font-bold text-secondary-800 group-hover:text-primary-500 transition-colors leading-snug">
      {title}
    </h3>
    <div class="flex items-center gap-1.5 mt-1 text-secondary-400">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="text-sm">{postalCode} {location}</span>
    </div>

    <!-- Features -->
    <div class="flex items-center gap-5 mt-4 pt-4 border-t border-gray-100">
      <div class="flex items-center gap-1.5 text-sm text-secondary-500">
        <svg class="w-[18px] h-[18px] text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="font-medium">{bedrooms}</span>
        <span class="text-secondary-300">kamers</span>
      </div>
      <div class="flex items-center gap-1.5 text-sm text-secondary-500">
        <svg class="w-[18px] h-[18px] text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
        </svg>
        <span class="font-medium">{area}</span>
        <span class="text-secondary-300">m&sup2;</span>
      </div>
    </div>
  </div>
</a>
