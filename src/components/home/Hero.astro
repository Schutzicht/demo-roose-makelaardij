---
import Button from '../ui/Button.astro';
import { type Lang, t } from '../../data/translations';

interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const prefix = lang === 'nl' ? '' : `/${lang}`;
---

<section data-hero class="relative min-h-[85vh] sm:min-h-[90vh] flex items-center -mt-16 sm:-mt-20 lg:-mt-24">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/80 via-primary-800/70 to-secondary-800/80 z-10"></div>
    <img src="/fotos roose maakelaardij/foto van gebouw vanaf buiten 2.jpeg" alt="Kantoor Roose Makelaardij Zoutelande" class="w-full h-full object-cover" loading="eager" />
  </div>

  <div class="absolute inset-0 z-10 hidden sm:block">
    <div class="absolute top-1/4 left-10 w-72 h-72 bg-primary-400/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-10 w-96 h-96 bg-primary-300/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-24 sm:py-32">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-3 py-1.5 sm:px-4 sm:py-2 mb-6 sm:mb-8 animate-fade-in">
        <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
        <span class="text-xs sm:text-sm text-white/90 font-medium">{t('hero.badge', lang)}</span>
      </div>

      <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4 sm:mb-6 animate-slide-up" style="animation-delay: 0.1s;">
        {t('hero.title1', lang)}{' '}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-200 to-primary-400">{t('hero.title2', lang)}</span>
      </h1>

      <p class="text-base sm:text-xl text-white/80 leading-relaxed mb-8 sm:mb-10 max-w-2xl animate-slide-up" style="animation-delay: 0.2s;">
        {t('hero.subtitle', lang)}
      </p>

      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 animate-slide-up" style="animation-delay: 0.3s;">
        <Button href={`${prefix}/aanbod/`} variant="white" size="lg" class="text-sm sm:text-base">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          {t('hero.cta1', lang)}
        </Button>
        <Button href={`${prefix}/diensten/waardebepaling/`} variant="outline" size="lg" class="border-white/30 text-white hover:bg-white hover:text-secondary-800 text-sm sm:text-base">
          {t('hero.cta2', lang)}
        </Button>
      </div>

      <div class="flex items-center gap-5 sm:gap-8 mt-8 sm:mt-12 pt-6 sm:pt-8 border-t border-white/10 animate-slide-up" style="animation-delay: 0.4s;">
        <div>
          <span class="block text-2xl sm:text-3xl font-bold text-white">45+</span>
          <span class="text-xs sm:text-sm text-white/60">{t('hero.experience', lang)}</span>
        </div>
        <div class="w-px h-8 sm:h-10 bg-white/20"></div>
        <div>
          <span class="block text-2xl sm:text-3xl font-bold text-white">NVM</span>
          <span class="text-xs sm:text-sm text-white/60">{t('hero.certified', lang)}</span>
        </div>
        <div class="w-px h-8 sm:h-10 bg-white/20"></div>
        <div>
          <span class="block text-2xl sm:text-3xl font-bold text-white">Funda</span>
          <span class="text-xs sm:text-sm text-white/60">{t('hero.partner', lang)}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce hidden sm:block">
    <svg class="w-6 h-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
  </div>
</section>
