---
import SectionHeading from '../ui/SectionHeading.astro';
import { type Lang, t } from '../../data/translations';

interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const prefix = lang === 'nl' ? '' : `/${lang}`;

const services = [
  {
    title: t('services.sellTitle', lang),
    description: t('services.sellDesc', lang),
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    href: '/diensten/verkopen/',
    image: '/fotos roose maakelaardij/foto van kantoorpand vanaf buiten.jpeg',
  },
  {
    title: t('services.valuationTitle', lang),
    description: t('services.valuationDesc', lang),
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
    href: '/diensten/waardebepaling/',
    image: '/fotos roose maakelaardij/Achter de receptie.jpeg',
  },
  {
    title: t('services.searchTitle', lang),
    description: t('services.searchDesc', lang),
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`,
    href: '/diensten/inschrijven/',
    image: '/fotos roose maakelaardij/Foto vanaf buiten close up .jpeg',
  },
];
---

<section class="py-24 bg-white relative overflow-hidden">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml,<svg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"><g fill=\"none\" fill-rule=\"evenodd\"><g fill=\"%23196895\" fill-opacity=\"1\"><path d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/></g></g></svg>');"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeading subtitle={t('services.subtitle', lang)}>
        {t('services.title', lang)}
      </SectionHeading>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {services.map((service, i) => (
        <a href={service.href} class="reveal group block" style={`transition-delay: ${i * 0.1}s;`}>
          <div class="relative rounded-2xl overflow-hidden bg-white shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 h-full">
            <!-- Image top -->
            <div class="relative h-48 overflow-hidden">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary-900/60 to-transparent"></div>
              <div class="absolute bottom-4 left-4">
                <div class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-xl flex items-center justify-center text-white border border-white/20">
                  <Fragment set:html={service.icon} />
                </div>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-secondary-800 mb-2 group-hover:text-primary-500 transition-colors">{service.title}</h3>
              <p class="text-secondary-500 text-sm leading-relaxed mb-4">{service.description}</p>
              <span class="inline-flex items-center gap-2 text-primary-500 font-semibold text-sm">
                {t('services.more', lang)}
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
