---
import { type Lang, t } from '../../data/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;

const stats = [
  { value: '500+', label: t('stats.sold', lang), icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>` },
  { value: '45+', label: t('stats.experience', lang), icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>` },
  { value: '9.2', label: t('stats.rating', lang), icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>` },
  { value: '8', label: t('stats.locations', lang), icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>` },
];
---

<section class="py-20 relative overflow-hidden">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1523217582562-09d0def993a6?w=1920&q=60" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-primary-900/85 backdrop-blur-sm"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {stats.map((stat, i) => (
        <div class="reveal text-center" style={`transition-delay: ${i * 0.1}s;`}>
          <div class="w-14 h-14 mx-auto mb-4 bg-white/10 rounded-2xl flex items-center justify-center text-primary-300 border border-white/10">
            <Fragment set:html={stat.icon} />
          </div>
          <span class="block text-4xl sm:text-5xl font-extrabold text-white mb-1 tracking-tight">{stat.value}</span>
          <span class="text-primary-300 text-sm font-medium uppercase tracking-wider">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
