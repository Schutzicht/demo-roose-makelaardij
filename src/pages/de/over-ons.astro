---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Stats from '../../components/home/Stats.astro';
import CTA from '../../components/global/CTA.astro';
import { siteConfig } from '../../data/siteConfig';
---

<BaseLayout lang="de" title="Uber uns" description="Lernen Sie Roose Makelaardij kennen - seit uber 45 Jahren Ihr zuverlassiger NVM-Makler in Zoutelande.">
  <section class="bg-gradient-to-br from-primary-500 to-primary-700 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold text-white mb-4">Uber Roose Makelaardij</h1>
      <p class="text-primary-100 text-lg max-w-2xl mx-auto">
        Seit uber 45 Jahren Ihr vertrauenswurdiger Partner fur Immobilien
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <img
            src="/fotos roose maakelaardij/foto van gebouw vanaf buiten 2.jpeg"
            alt="Buro Roose Makelaardij in Zoutelande"
            class="w-full aspect-[4/3] object-cover rounded-2xl"
            loading="lazy"
          />
        </div>
        <div class="reveal" style="transition-delay: 0.15s;">
          <span class="text-sm font-bold uppercase tracking-widest text-primary-500 mb-3 block">Unsere Geschichte</span>
          <h2 class="text-3xl font-bold text-secondary-800 mb-6">Seit 1979 in Zeeland verwurzelt</h2>
          <div class="space-y-4 text-secondary-500 leading-relaxed">
            <p>
              Roose Makelaardij wurde 1979 gegrundet und hat sich seitdem zu einem festen Begriff an der Walcherer Kuste entwickelt. Von unserem Buro am Langendam 43 in Zoutelande bedienen wir ein breites Gebiet von Westkapelle bis Vlissingen.
            </p>
            <p>
              Als Mitglied der NVM und Partner von Funda garantieren wir Ihnen eine professionelle und zuverlassige Dienstleistung. Unsere Starke liegt in unserem personlichen Ansatz und unserer fundierten Kenntnis des lokalen Wohnungsmarktes.
            </p>
            <p>
              Ob es sich um ein stimmungsvolles Ferienhaus, ein charakteristisches Dorfhaus oder ein modernes Neubauprojekt handelt - wir kennen jede Strasse, jede Nachbarschaft und jede Moglichkeit in unserem Gebiet.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Stats lang="de" />

  <!-- Values -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <SectionHeading subtitle="Unsere Kernwerte">
          Wofur wir stehen
        </SectionHeading>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { title: 'Zuverlassig', description: 'Als NVM-Mitglied garantieren wir ehrliche und transparente Beratung.', icon: '🤝' },
          { title: 'Lokale Expertise', description: 'Mehr als 45 Jahre Kenntnis des Walcherer Wohnungsmarktes.', icon: '📍' },
          { title: 'Personlich', description: 'Sie sind keine Nummer. Wir kennen unsere Kunden beim Namen.', icon: '❤️' },
          { title: 'Ergebnisorientiert', description: 'Wir streben immer das beste Ergebnis fur Sie an.', icon: '🎯' },
        ].map((value, i) => (
          <div class="reveal text-center p-6" style={`transition-delay: ${i * 0.1}s;`}>
            <span class="text-4xl mb-4 block">{value.icon}</span>
            <h3 class="text-lg font-bold text-secondary-800 mb-2">{value.title}</h3>
            <p class="text-sm text-secondary-500">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Office info -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <SectionHeading subtitle="Unser Buro">
          Besuchen Sie uns gerne
        </SectionHeading>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 reveal">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <h3 class="font-bold text-secondary-800 mb-4">Adresse</h3>
              <p class="text-secondary-500 text-sm">{siteConfig.contact.address}</p>
              <p class="text-secondary-500 text-sm">{siteConfig.contact.postalCode} {siteConfig.contact.city}</p>
              <p class="text-secondary-500 text-sm mt-4">
                <a href={`tel:${siteConfig.contact.phone}`} class="text-primary-500 hover:text-primary-600 font-medium">
                  {siteConfig.contact.phone}
                </a>
              </p>
              <p class="text-secondary-500 text-sm">
                <a href={`mailto:${siteConfig.contact.email}`} class="text-primary-500 hover:text-primary-600 font-medium">
                  {siteConfig.contact.email}
                </a>
              </p>
            </div>
            <div>
              <h3 class="font-bold text-secondary-800 mb-4">Offnungszeiten</h3>
              <ul class="space-y-1.5">
                {siteConfig.openingHours.map((item) => (
                  <li class="flex justify-between text-sm">
                    <span class="text-secondary-500">{item.day}</span>
                    <span class="text-secondary-700 font-medium">{item.hours}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA lang="de" />
</BaseLayout>
