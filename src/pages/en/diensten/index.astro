---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/ui/Button.astro';
import CTA from '../../../components/global/CTA.astro';
import { getCollection } from 'astro:content';

const diensten = (await getCollection('diensten'))
  .sort((a, b) => a.data.order - b.data.order);

const icons: Record<string, string> = {
  building: `<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
  calculator: `<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
  search: `<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`,
};
---

<BaseLayout lang="en" title="Services" description="Discover the services of Roose Makelaardij: property sales, valuations and property search.">
  <section class="bg-gradient-to-br from-primary-500 to-primary-700 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold text-white mb-4">Our services</h1>
      <p class="text-primary-100 text-lg max-w-2xl mx-auto">
        From sales to valuations - we are here for you
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {diensten.map((dienst, i) => (
          <div class="reveal group" style={`transition-delay: ${i * 0.1}s;`}>
            <div class="bg-white rounded-2xl border border-gray-100 hover:shadow-xl transition-all duration-300 p-8 h-full flex flex-col">
              <div class="w-20 h-20 bg-primary-50 rounded-2xl flex items-center justify-center text-primary-500 group-hover:bg-primary-500 group-hover:text-white transition-all duration-300 mb-6">
                <Fragment set:html={icons[dienst.data.icon] || icons.building} />
              </div>
              <h2 class="text-2xl font-bold text-secondary-800 mb-3">{dienst.data.title}</h2>
              <p class="text-secondary-500 leading-relaxed mb-6 flex-grow">{dienst.data.description}</p>
              <Button href={`/en/diensten/${dienst.id}/`} variant="outline" size="md">
                More information
              </Button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
