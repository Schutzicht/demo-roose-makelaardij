---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Pagina niet gevonden">
  <section class="py-32">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <span class="text-8xl font-bold text-primary-100 block mb-4">404</span>
      <h1 class="text-3xl font-bold text-secondary-800 mb-4">Pagina niet gevonden</h1>
      <p class="text-secondary-500 mb-8">
        De pagina die u zoekt bestaat niet of is verplaatst.
        Misschien kunnen wij u helpen bij het vinden van uw droomwoning?
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" variant="primary" size="lg">
          Terug naar home
        </Button>
        <Button href="/aanbod/" variant="outline" size="lg">
          Bekijk woningaanbod
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
