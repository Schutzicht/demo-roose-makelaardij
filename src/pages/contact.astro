---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout title="Contact" description="Neem contact op met Roose Makelaardij. Bel, mail of kom langs op ons kantoor in Zoutelande.">
  <section class="bg-gradient-to-br from-primary-500 to-primary-700 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold text-white mb-4">Contact</h1>
      <p class="text-primary-100 text-lg max-w-2xl mx-auto">
        Wij staan graag voor u klaar. Neem gerust contact met ons op.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Contact form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
            <h2 class="text-2xl font-bold text-secondary-800 mb-6">Stuur ons een bericht</h2>
            <form class="space-y-5" action="#" method="POST">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-secondary-700 mb-1.5">Naam *</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="Uw volledige naam" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-secondary-700 mb-1.5">Telefoon</label>
                  <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="Uw telefoonnummer" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-secondary-700 mb-1.5">E-mailadres *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="uw@email.nl" />
              </div>
              <div>
                <label for="subject" class="block text-sm font-medium text-secondary-700 mb-1.5">Onderwerp</label>
                <select id="subject" name="subject" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm bg-white">
                  <option value="">Selecteer een onderwerp</option>
                  <option value="verkoop">Mijn woning verkopen</option>
                  <option value="aankoop">Een woning kopen</option>
                  <option value="waardebepaling">Waardebepaling aanvragen</option>
                  <option value="bezichtiging">Bezichtiging plannen</option>
                  <option value="overig">Overig</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-secondary-700 mb-1.5">Bericht *</label>
                <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm resize-none" placeholder="Uw bericht..."></textarea>
              </div>
              <Button variant="primary" size="lg" class="w-full sm:w-auto">
                Verstuur bericht
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </Button>
            </form>
          </div>
        </div>

        <!-- Contact info sidebar -->
        <div class="lg:col-span-2">
          <div class="space-y-6">
            <!-- Direct contact -->
            <div class="bg-primary-500 rounded-2xl p-6 text-white">
              <h3 class="font-bold text-lg mb-4">Direct contact</h3>
              <div class="space-y-4">
                <a href={`tel:${siteConfig.contact.phone}`} class="flex items-center gap-3 text-primary-100 hover:text-white transition-colors">
                  <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="font-medium">{siteConfig.contact.phone}</span>
                </a>
                <a href={`mailto:${siteConfig.contact.email}`} class="flex items-center gap-3 text-primary-100 hover:text-white transition-colors">
                  <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <span class="font-medium">{siteConfig.contact.email}</span>
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="bg-white rounded-2xl border border-gray-100 p-6">
              <h3 class="font-bold text-secondary-800 mb-4">Kantooradres</h3>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div class="text-sm text-secondary-500">
                  <p class="font-medium text-secondary-700">{siteConfig.name}</p>
                  <p>{siteConfig.contact.address}</p>
                  <p>{siteConfig.contact.postalCode} {siteConfig.contact.city}</p>
                </div>
              </div>
            </div>

            <!-- Opening hours -->
            <div class="bg-white rounded-2xl border border-gray-100 p-6">
              <h3 class="font-bold text-secondary-800 mb-4">Openingstijden</h3>
              <ul class="space-y-2">
                {siteConfig.openingHours.map((item) => (
                  <li class="flex justify-between text-sm">
                    <span class="text-secondary-500">{item.day}</span>
                    <span class="text-secondary-700 font-medium">{item.hours}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Social -->
            <div class="bg-white rounded-2xl border border-gray-100 p-6">
              <h3 class="font-bold text-secondary-800 mb-4">Volg ons</h3>
              <div class="flex gap-3">
                <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-gray-100 hover:bg-primary-500 hover:text-white rounded-lg flex items-center justify-center text-secondary-500 transition-all" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                </a>
                <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-gray-100 hover:bg-primary-500 hover:text-white rounded-lg flex items-center justify-center text-secondary-500 transition-all" aria-label="LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
