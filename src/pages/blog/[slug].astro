---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/global/CTA.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/helpers';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.image}>
  <!-- Header -->
  <section class="bg-gradient-to-br from-primary-500 to-primary-700 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav class="flex items-center justify-center gap-2 text-sm text-primary-200 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/blog/" class="hover:text-white transition-colors">Blog</a>
        <span>/</span>
        <span class="text-white truncate max-w-[200px]">{post.data.title}</span>
      </nav>
      <span class="inline-block text-xs font-bold uppercase tracking-wider text-primary-200 bg-white/10 px-3 py-1 rounded-full mb-4">{post.data.category}</span>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{post.data.title}</h1>
      <div class="flex items-center justify-center gap-4 text-sm text-primary-200">
        <span>{post.data.author}</span>
        <span>|</span>
        <time>{formatDate(post.data.publishDate)}</time>
      </div>
    </div>
  </section>

  <!-- Featured image -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
    <img
      src={post.data.image}
      alt={post.data.title}
      class="w-full aspect-[2/1] object-cover rounded-2xl shadow-xl"
    />
  </div>

  <!-- Content -->
  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg prose-secondary max-w-none prose-headings:text-secondary-800 prose-a:text-primary-500 prose-img:rounded-xl">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-12 pt-8 border-t border-gray-100">
        <a href="/blog/" class="inline-flex items-center gap-2 text-primary-500 hover:text-primary-600 font-medium text-sm group">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Terug naar alle artikelen
        </a>
      </div>
    </div>
  </section>

  <CTA title="Heeft u een vraag?" description="Neem gerust contact met ons op voor persoonlijk advies over de woningmarkt." />
</BaseLayout>
